> > 33L), r2 = c(17L, 48L, 42L, 14L, 24L, 9L, 30L, 28L, 47L, 105L, 12L, 25L, 22L,
> > 27L, 25L, 8L, 375L, 30L, 64L, 15L)), row.names = c(NA, 20L), class =
