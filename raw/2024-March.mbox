>>> vec <- c(1, 0, 0)
>>> pred <- sum(m2$beta * vec)
>>> Vb <- as.numeric(t(vec) %*% vcov(m2) %*% vec)
>>> V_RE <- sum(m2$sigma2) + m2$tau2[1] # Using only the random intercept at
>>> the study level
>>> S <- sqrt(Vb + V_RE)
>>> z_crit <- qnorm((1 + 0.8) / 2)
>>> pred + c(-1, 1) * z_crit * S
