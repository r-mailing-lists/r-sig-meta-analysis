df.gen <- df[!is.na(df$generality), ]

mod.generality <-  rma.mv(yi = z, 
                          V = vz, 
                          slab = auth, 
                          data = df.gen,
                          random = list(~generality | samid, ~generality | esid), 
                          test = "t", 
                          method = "REML",
                          dfs="contain",
