calc.v <- function(x) {
v <- matrix(r^2/(2*x$ni[1]-1), nrow=nrow(x), ncol=nrow(x))
diag(v) <- x$vi
v
}
V <- bldiag(lapply(split(dat, dat$study), calc.v))
http://www.metafor-project.org/doku.php/analyses:gleser2009

