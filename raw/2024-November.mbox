gamma_het<-round(model0r.mlcon$gamma2[1] + model0r.mlcon$gamma2[2] - 2*model0r.mlcon$phi*sqrt(model0r.mlcon$gamma2[1]*model0r.ml$gamma2[2]), 3)

res_het<-tau_study + gamma_type

