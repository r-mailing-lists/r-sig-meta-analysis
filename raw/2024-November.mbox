rDZse<- deltamethod(~ (exp(2*x1) - 1) / (exp(2*x1) + 1), coef(model0r.mlcon), vcov(model0r.mlcon))
rMZse<- deltamethod(~ (exp(2*x2) - 1) / (exp(2*x2) + 1), coef(model0r.mlcon), vcov(model0r.mlcon))
