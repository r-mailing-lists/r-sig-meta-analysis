               n1i = Case_N,
               sd1i = Case_sd,
               m2i = Control_mean,
               n2i = Control_N,
               sd2i = Control_sd,
               slab=paste(authors, year, sep=", "))

res <- rma.mv(yi, vi, data=dat1,random = ~ 1 | study_id, verbose=T)
weights(res)

Can you help me to understand this?

