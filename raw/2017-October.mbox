You just need to specify in the arguments whether it's sei or vi, eg,

# vi
res <- rma(measure="SMD", yi, vi=vi, data=re, method="FE", digits=2)

#sei
res <- rma(measure="SMD", yi, sei=sei, data=re, method="FE", digits=2)


