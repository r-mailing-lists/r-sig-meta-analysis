>> Tmat <- diag(tau, nrow = p) %*% Cmat %*% diag(tau, nrow = p)
>>
>> # study-specific adjustment to the average effect
>> sim$u <- c(t(MASS::mvrnorm(k, rep(0, p), Tmat)))
