>> minn <- 50 # minimum sample size
>> meann <- 100 # average sample size
>> rs <- 0.6 # sampling error correlation
>> r <- 0.6 # pre-post correlation (for the vi)
>> rho <- 0.7 # the between outcomes correlation
>> tau <- 0.4 # the outcomes tau
>>
